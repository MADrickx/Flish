POSTGRES_DB=flish
POSTGRES_USER=flish
POSTGRES_PASSWORD=change-this-password

FLISH_BASIC_USER=admin
FLISH_BASIC_PASSWORD=change-this-password-too

JWT_SECRET_KEY=change-this-to-a-random-64-char-string-for-hmac-sha256-signing
JWT_ISSUER=flish
JWT_AUDIENCE=flish-client
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Absolute path on the VPS host; mounted into the API container at /data/master (see deploy.md)
MASTER_DIRECTORY=/home/flish/storage
WEB_PORT=1604
MAX_UPLOAD_BYTES=524288000
SCAN_INTERVAL_SECONDS=300
